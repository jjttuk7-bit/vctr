# KNow 환경변수 템플릿
# 복사 후 .env로 이름 변경, 실제 값 입력 (절대 커밋 금지)
# GitHub Actions: Settings → Secrets and variables → Actions에 등록

# ── LLM ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── 수집 ─────────────────────────────────────────────
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# ── 이미지 ───────────────────────────────────────────
UNSPLASH_ACCESS_KEY=your_unsplash_access_key
YOUTUBE_API_KEY=your_youtube_api_key          # K-Pop·K-Drama 썸네일용

# ── 알림 ─────────────────────────────────────────────
BUTTONDOWN_API_KEY=your_buttondown_api_key
DISCORD_WEBHOOK=https://discord.com/api/webhooks/...
# TWITTER_API_KEY=                            # v1.1에서 활성화

# ── 웹사이트 (로컬 개발용) ────────────────────────────
DB_PATH=../data/know.db                       # website/ 기준 상대경로
