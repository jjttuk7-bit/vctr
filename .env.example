# Vctr environment variables template
# Copy to .env, fill in real values (never commit .env)
# GitHub Actions: Settings → Secrets and variables → Actions

# ── LLM ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Data collection ───────────────────────────────────
PRODUCTHUNT_API_KEY=your_producthunt_api_key   # https://www.producthunt.com/v2/oauth/applications
REDDIT_CLIENT_ID=your_reddit_client_id         # https://www.reddit.com/prefs/apps → script app
REDDIT_CLIENT_SECRET=your_reddit_client_secret

# ── Images ───────────────────────────────────────────
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# ── Notifications ─────────────────────────────────────
BUTTONDOWN_API_KEY=your_buttondown_api_key
DISCORD_WEBHOOK=https://discord.com/api/webhooks/...

# ── Website (local dev) ───────────────────────────────
DB_PATH=../data/vctr.db                        # relative to website/
